@model List<Universetechgeek.Models.TvShow>

@{
    ViewData["Title"] = "TV Shows";
}

<main class="container mx-auto px-4 py-12">

    <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-8 gap-4">

        <!-- Title -->
        <div class="border-l-4 border-blue-600 pl-4">
            <h2 class="text-3xl font-bold">Séries em Tendência</h2>
            <p class="text-gray-500">As séries mais populares do momento</p>
        </div>

        <!-- Search Bar -->
        <div class="w-full md:max-w-sm">
            <div class="relative flex items-center">
                <svg style="position:absolute; left:14px; color:#9ca3af;" width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z" />
                </svg>
                <input type="text" id="search-input" placeholder="Pesquisar séries..."
                       style="width:100%; border:1px solid #d1d5db; border-radius:8px; padding:12px 16px 12px 44px; outline:none; font-size:14px; background:transparent;" />
            </div>
        </div>

    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-6">
        @foreach (var show in Model)
        {
            <a href="/TvShows/Details/@show.Id" class="space-y-3 hover-card cursor-pointer group">
                <div class="aspect-[2/3] rounded-md overflow-hidden shadow-sm">
                    <img src="@show.ImageUrl" alt="@show.Title" class="w-full h-full object-cover rounded" />
                </div>
                <h3 class="text-sm font-semibold leading-tight">@show.Title</h3>
                <span class="text-xs">★ @show.Rating</span>
            </a>
        }
    </div>

</main>
